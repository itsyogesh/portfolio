{
  "name": "@packages/db",
  "version": "0.0.0",
  "private": true,
  "main": "./index.ts",
  "types": "./index.ts",
  "scripts": {
    "analyze": "prisma generate --no-hints --schema=./prisma/schema.prisma",
    "build": "prisma generate --no-hints --schema=./prisma/schema.prisma",
    "postinstall": "prisma generate --no-hints --schema=./prisma/schema.prisma",
    "db:push": "prisma db push --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "7.1.0",
    "@prisma/client": "7.1.0",
    "@prisma/client-runtime-utils": "^7.1.0",
    "@t3-oss/env-nextjs": "^0.13.8",
    "server-only": "^0.0.1",
    "ws": "^8.18.3",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@tooling/typescript-config": "workspace:*",
    "@types/node": "24.10.1",
    "@types/ws": "^8.18.1",
    "dotenv": "^16.4.7",
    "prisma": "7.1.0",
    "typescript": "^5.9.3"
  }
}
