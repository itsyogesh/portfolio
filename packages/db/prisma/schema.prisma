generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

// ─── Better Auth Models ──────────────────────────────────────────────

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// ─── Bookmarks ───────────────────────────────────────────────────────

model Bookmark {
  id          String   @id @default(cuid())
  title       String
  url         String
  originalUrl String?
  archived    Boolean  @default(false)

  // Categorization
  category   String   @default("Other")
  tags       String[]

  // AI-generated
  summary    String?

  // Extracted article content
  fullText   String?
  excerpt    String?
  author     String?
  siteName   String?
  imageUrl   String?
  favicon    String?

  // Visibility
  isPublic   Boolean @default(true)
  isFeatured Boolean @default(false)

  // Original save date (from Pocket)
  savedAt DateTime?

  // Processing status
  extractionStatus String  @default("pending")
  aiStatus         String  @default("pending")
  extractionError  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isPublic])
  @@index([extractionStatus])
  @@index([aiStatus])
  @@index([savedAt])
  @@index([url])
  @@map("bookmark")
}

// ─── Portfolio: Profile ──────────────────────────────────────────────

model Profile {
  id        String @id @default("owner")
  name      String
  headline  String?
  bio       String?
  avatarUrl String?
  location  String?
  website   String?
  resumeUrl String?

  socials SocialLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profile")
}

model SocialLink {
  id        String @id @default(cuid())
  platform  String
  url       String
  label     String?
  position  Int    @default(0)

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("social_link")
}

// ─── Portfolio: Organizations & Work Experience ──────────────────────

model Organization {
  id          String  @id @default(cuid())
  name        String
  description String?
  logoUrl     String?
  website     String?
  location    String?
  type        String  @default("company") // company, nonprofit, community, freelance

  workExperiences WorkExperience[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organization")
}

model WorkExperience {
  id          String    @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  type        String    @default("fulltime") // fulltime, contract, freelance, founder
  position    Int       @default(0)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("work_experience")
}

// ─── Portfolio: Projects ─────────────────────────────────────────────

model Project {
  id        String    @id @default(cuid())
  title     String
  slug      String    @unique
  summary   String?
  content   String?
  status    String    @default("concept") // active, building, shipped, legacy, concept
  category  String?
  tech      String[]
  url       String?
  githubUrl String?
  imageUrl  String?
  featured  Boolean   @default(false)
  position  Int       @default(0)
  startDate DateTime?
  endDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project")
}

// ─── Portfolio: Education ────────────────────────────────────────────

model Education {
  id          String    @id @default(cuid())
  institution String
  degree      String?
  field       String?
  description String?
  startDate   DateTime?
  endDate     DateTime?
  logoUrl     String?
  position    Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("education")
}

// ─── Portfolio: Accolades ────────────────────────────────────────────

model Accolade {
  id          String    @id @default(cuid())
  title       String
  issuer      String?
  type        String    @default("award") // award, certification, grant, hackathon, publication
  description String?
  url         String?
  date        DateTime?
  imageUrl    String?
  position    Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("accolade")
}

// ─── Portfolio: Stack ────────────────────────────────────────────────

model StackCategory {
  id       String      @id @default(cuid())
  name     String
  position Int         @default(0)

  items StackItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("stack_category")
}

model StackItem {
  id          String  @id @default(cuid())
  name        String
  description String?
  logoUrl     String?
  url         String?
  position    Int     @default(0)

  categoryId String
  category   StackCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, name])
  @@map("stack_item")
}

// ─── Portfolio: Timeline ─────────────────────────────────────────────

model TimelineEntry {
  id          String  @id @default(cuid())
  year        String
  title       String
  description String?
  position    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, title])
  @@map("timeline_entry")
}

// ─── Portfolio: External Writing ─────────────────────────────────────

model ExternalWriting {
  id          String    @id @default(cuid())
  title       String
  url         String    @unique
  source      String?   // substack, medium, twitter, etc.
  publishedAt DateTime?
  summary     String?
  tags        String[]
  imageUrl    String?
  featured    Boolean   @default(false)
  position    Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("external_writing")
}

// ─── Stars ───────────────────────────────────────────────────────────

model StarList {
  id          String  @id @default(cuid())
  name        String
  description String?
  color       String?
  position    Int     @default(0)

  repos StarRepo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("star_list")
}

model StarRepo {
  id              String   @id @default(cuid())
  githubId        Int      @unique
  fullName        String
  htmlUrl         String
  description     String?
  language        String?
  stargazersCount Int      @default(0)
  topics          String[]
  avatarUrl       String?
  position        Int      @default(0)

  // Soft cleanup
  isStarred   Boolean   @default(true)
  unstarredAt DateTime?

  listId String?
  list   StarList? @relation(fields: [listId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("star_repo")
}
