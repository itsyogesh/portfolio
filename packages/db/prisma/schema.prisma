generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

// ─── Better Auth Models ──────────────────────────────────────────────

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// ─── Bookmarks ───────────────────────────────────────────────────────

model Bookmark {
  id          String   @id @default(cuid())
  title       String
  url         String
  originalUrl String?
  archived    Boolean  @default(false)

  // Categorization
  category   String   @default("Other")
  tags       String[]

  // AI-generated
  summary    String?

  // Extracted article content
  fullText   String?
  excerpt    String?
  author     String?
  siteName   String?
  imageUrl   String?
  favicon    String?

  // Visibility
  isPublic   Boolean @default(true)
  isFeatured Boolean @default(false)

  // Original save date (from Pocket)
  savedAt DateTime?

  // Processing status
  extractionStatus String  @default("pending")
  aiStatus         String  @default("pending")
  extractionError  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isPublic])
  @@index([extractionStatus])
  @@index([aiStatus])
  @@index([savedAt])
  @@index([url])
  @@map("bookmark")
}

// ─── Portfolio: Profile ──────────────────────────────────────────────

model Profile {
  id        String @id @default("owner")
  name      String
  headline  String?
  bio       String?
  avatarUrl String?
  location  String?
  website   String?
  resumeUrl String?
  email     String?
  phone     String?

  socials SocialLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profile")
}

model SocialLink {
  id        String @id @default(cuid())
  platform  String
  url       String
  label     String?
  position  Int    @default(0)

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("social_link")
}

// ─── Portfolio: Organizations & Work Experience ──────────────────────

model Organization {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  logoUrl     String?
  website     String?
  location    String?
  type        String  @default("company") // company, nonprofit, community, freelance
  industry    String?

  workExperiences WorkExperience[]
  projects        Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organization")
}

model WorkExperience {
  id          String    @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  type        String    @default("fulltime") // fulltime, contract, freelance, founder
  highlights  String[]
  position    Int       @default(0)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("work_experience")
}

// ─── Portfolio: Projects ─────────────────────────────────────────────

model Project {
  id        String    @id @default(cuid())
  title     String
  slug      String    @unique
  summary   String?
  content   String?
  status    String    @default("concept") // active, building, shipped, legacy, concept
  category  String?
  tech      String[]
  url       String?
  githubUrl String?
  imageUrl  String?
  featured  Boolean   @default(false)
  position  Int       @default(0)
  startDate DateTime?
  endDate   DateTime?
  kind      String?   // product, client, oss, internal, experiment
  role      String?   // creator, lead, contributor, maintainer
  highlights String[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project")
}

// ─── Portfolio: Education ────────────────────────────────────────────

model Education {
  id          String    @id @default(cuid())
  institution String
  degree      String?
  field       String?
  description String?
  startDate   DateTime?
  endDate     DateTime?
  logoUrl     String?
  url         String?
  gpa         String?
  courses     String[]
  position    Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("education")
}

// ─── Portfolio: Accolades ────────────────────────────────────────────

model Accolade {
  id          String    @id @default(cuid())
  title       String
  issuer      String?
  type        String    @default("award") // award, certification, grant, hackathon, publication
  description String?
  url         String?
  date        DateTime?
  imageUrl    String?
  position    Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("accolade")
}

// ─── Portfolio: Stack ────────────────────────────────────────────────

model StackCategory {
  id       String      @id @default(cuid())
  name     String
  position Int         @default(0)

  items StackItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("stack_category")
}

model StackItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  iconSlug    String?  // Simple Icons slug, e.g. "typescript", "nextdotjs"
  logoUrl     String?  // Fallback for icons not in Simple Icons
  url         String?
  level       String?  // beginner, intermediate, advanced, expert
  keywords    String[]
  position    Int      @default(0)

  categoryId String
  category   StackCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, name])
  @@map("stack_item")
}

// ─── Portfolio: Languages ────────────────────────────────────────────

model Language {
  id       String  @id @default(cuid())
  name     String  @unique
  fluency  String? // native, fluent, professional, elementary
  position Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("language")
}

// ─── Portfolio: Timeline ─────────────────────────────────────────────

model TimelineEntry {
  id          String  @id @default(cuid())
  year        String
  title       String
  description String?
  position    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, title])
  @@map("timeline_entry")
}

// ─── Portfolio: External Writing ─────────────────────────────────────

model ExternalWriting {
  id          String    @id @default(cuid())
  title       String
  url         String    @unique
  source      String?   // substack, medium, twitter, etc.
  publishedAt DateTime?
  summary     String?
  tags        String[]
  imageUrl    String?
  featured    Boolean   @default(false)
  position    Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("external_writing")
}

// ─── Stars ───────────────────────────────────────────────────────────

model StarList {
  id          String  @id @default(cuid())
  name        String
  description String?
  color       String?
  position    Int     @default(0)

  repos StarRepo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("star_list")
}

model StarRepo {
  id              String   @id @default(cuid())
  githubId        Int      @unique
  fullName        String
  htmlUrl         String
  description     String?
  language        String?
  stargazersCount Int      @default(0)
  topics          String[]
  avatarUrl       String?
  position        Int      @default(0)

  // Soft cleanup
  isStarred   Boolean   @default(true)
  unstarredAt DateTime?

  listId String?
  list   StarList? @relation(fields: [listId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("star_repo")
}

// ─── Calendar & Scheduling ────────────────────────────────────────

model GoogleAccount {
  id                    String    @id @default(cuid())
  googleEmail           String
  googleAccountId       String    @unique
  displayName           String?
  encryptedAccessToken  String
  encryptedRefreshToken String
  accessTokenExpiresAt  DateTime
  scope                 String
  status                String    @default("active")
  color                 String    @default("#4285f4")

  calendars    GoogleCalendar[]
  cachedEvents CalendarEventCache[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("google_account")
}

model GoogleCalendar {
  id               String   @id @default(cuid())
  googleCalendarId String
  summary          String
  color            String?
  isVisible        Boolean  @default(true)
  isPrimary        Boolean  @default(false)
  accessRole       String   @default("reader")

  syncToken    String?
  lastSyncedAt DateTime?

  googleAccountId String
  googleAccount   GoogleAccount @relation(fields: [googleAccountId], references: [id], onDelete: Cascade)

  cachedEvents        CalendarEventCache[]
  eventTypeCheckLinks EventTypeCheckCalendar[]
  targetEventTypes    EventType[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([googleAccountId, googleCalendarId])
  @@map("google_calendar")
}

model CalendarEventCache {
  id            String   @id @default(cuid())
  googleEventId String
  summary       String?
  description   String?
  location      String?
  startTime     DateTime
  endTime       DateTime
  isAllDay      Boolean  @default(false)
  status        String   @default("confirmed")
  htmlLink      String?

  calendarId      String
  calendar        GoogleCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  googleAccountId String
  googleAccount   GoogleAccount  @relation(fields: [googleAccountId], references: [id], onDelete: Cascade)

  syncedAt DateTime @default(now())

  @@unique([calendarId, googleEventId])
  @@index([startTime])
  @@index([endTime])
  @@index([calendarId])
  @@map("calendar_event_cache")
}

model EventType {
  id              String  @id @default(cuid())
  slug            String  @unique
  title           String
  description     String?
  durationMinutes Int
  color           String?
  isActive        Boolean @default(true)
  bufferBefore    Int     @default(0)
  bufferAfter     Int     @default(0)
  minNotice       Int     @default(60)
  maxFutureDays   Int     @default(60)
  availability    Json
  timezone        String  @default("Asia/Kolkata")

  targetCalendarId String?
  targetCalendar   GoogleCalendar? @relation(fields: [targetCalendarId], references: [id], onDelete: SetNull)

  checkCalendars EventTypeCheckCalendar[]
  bookings       Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("event_type")
}

model EventTypeCheckCalendar {
  id String @id @default(cuid())

  eventTypeId String
  eventType   EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)

  calendarId String
  calendar   GoogleCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@unique([eventTypeId, calendarId])
  @@map("event_type_check_calendar")
}

model Booking {
  id             String    @id @default(cuid())
  idempotencyKey String?   @unique

  eventTypeId String
  eventType   EventType @relation(fields: [eventTypeId], references: [id])

  bookerName       String
  bookerEmail      String
  bookerTimezone   String
  startTime        DateTime
  endTime          DateTime
  status           String   @default("confirmed")
  googleEventId    String?
  notes            String?
  cancelledAt      DateTime?
  cancelReason     String?
  targetCalendarId String?  // denormalized from EventType for exclusion constraint

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventTypeId])
  @@index([startTime])
  @@index([bookerEmail])
  @@map("booking")
}
