# Neon PostgreSQL
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Better Auth
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3001"

# Owner email — only this user can access backstage
OWNER_EMAIL=""

# OpenAI — for AI bookmark processing (optional)
OPENAI_API_KEY=""

# GitHub OAuth (optional — enables social login + stars sync)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# GitHub (optional — for stars sync without OAuth)
GITHUB_USERNAME=""
GITHUB_TOKEN=""
