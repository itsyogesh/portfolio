# Neon PostgreSQL
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Better Auth
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:4001"

# Owner email — only this user can access backstage
OWNER_EMAIL=""

# OpenAI — for AI bookmark processing (optional)
OPENAI_API_KEY=""

# GitHub OAuth (optional — enables social login + stars sync)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# GitHub (optional — for stars sync without OAuth)
GITHUB_USERNAME=""
GITHUB_TOKEN=""

# Google Calendar OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:4001/api/calendar/callback"
CALENDAR_ENCRYPTION_KEY=""  # 32-byte hex for token encryption
